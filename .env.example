# Supabase 설정
# 이유: 현재 코드베이스는 별도 service role 없이 anon key 기반의 SSR/auth 흐름을 사용합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Slack 설정 (optional - 비어있으면 알림 비활성화)
# 이유: Slack Webhook은 선택 기능이라 운영 환경에서도 필요할 때만 추가하면 됩니다.
SLACK_WEBHOOK_URL=
